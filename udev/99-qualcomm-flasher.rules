# Qualcomm device access rules for 2flasher
# Install: sudo cp 99-qualcomm-flasher.rules /etc/udev/rules.d/
#          sudo udevadm control --reload-rules && sudo udevadm trigger
#
# EDL mode (Emergency Download) — 05c6:9008
SUBSYSTEM=="usb", ATTRS{idVendor}=="05c6", ATTRS{idProduct}=="9008", MODE="0666"

# User booted — 18d1:4ee1
SUBSYSTEM=="usb", ATTRS{idVendor}=="18d1", ATTRS{idProduct}=="4ee1", MODE="0666"

# Debug booted — 18d1:4e11
SUBSYSTEM=="usb", ATTRS{idVendor}=="18d1", ATTRS{idProduct}=="4e11", MODE="0666"

# Debug booted (alt) — 05c6:901f
SUBSYSTEM=="usb", ATTRS{idVendor}=="05c6", ATTRS{idProduct}=="901f", MODE="0666"
